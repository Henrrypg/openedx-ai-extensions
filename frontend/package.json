{
  "name": "@openedx/openedx-ai-badges-ui",
  "version": "1.4.1",
  "description": "AI Badges UI component for Open edX utilizing Frontend Plugin Framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "sideEffects": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openedx/openedx-ai-badges.git"
  },
  "browserslist": [
    "extends @edx/browserslist-config"
  ],
  "scripts": {
    "build": "make build",
    "prepublishOnly": "npm run build",
    "lint": "fedx-scripts eslint --ext .js --ext .jsx --ext .ts --ext .tsx .",
    "lint:fix": "fedx-scripts eslint --fix --ext .js --ext .jsx --ext .ts --ext .tsx .",
    "types": "tsc --noEmit",
    "test": "fedx-scripts jest --coverage --passWithNoTests"
  },
  "author": "Open edX Community",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@edx/frontend-platform": "^7.0.0 || ^8.0.0",
    "@openedx/paragon": "^21.0.0 || ^22.0.0 || ^23.0.0",
    "@tanstack/react-query": "^4.36.1",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@edx/browserslist-config": "1.1.1",
    "@openedx/frontend-build": "14.6.0",
    "@openedx/paragon": "23.14.0",
    "@tanstack/react-query": "^4.43.0",
    "jest": "29.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "prop-types": "^15.8.1",
    "react-markdown": "^8.0.0 || ^9.0.0"
  }
}
